        {
          "point": "refresh_ms=0 (disabled)",
          "inputs": {"A2A_PARENT_REFRESH_MS": 0},
          "expectedSignal": {
            "cost.summary.cost.requests.byStage.attention": "higher (linear with parents)",
            "cost.summary.cost.refreshPlan.skippedByFreshCache": "0"
          },
          "gradedGate": "more likely WARN/FAIL due to attention cost high when parent count grows"
        },
        {
          "point": "refresh_ms>0 (enabled)",
          "inputs": {"A2A_PARENT_REFRESH_MS": 60000},
          "expectedSignal": {
            "cost.summary.cost.requests.byStage.attention": "lower vs disabled (growth slowdown)",
            "cost.summary.cost.refreshPlan.skippedByFreshCache": ">0"
          },
          "gradedGate": "more likely PASS/WARN (cost reasons reduced)"
        }
      ],
      "evidenceSources": [
        "docs/p6-1-refresh-policy.md",
        "docs/p7-1-capacity-cost-baseline.md",
        "docs/p8-1-threshold-catalog.md",
