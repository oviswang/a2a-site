          "targetField": "summary.cost.requests.byStage.attention",
          "expectedChange": "decrease",
          "evidencePathHint": "artifacts/p7-1-bench/<ts>/*/latest.summary.json",
          "compareWindow": "refresh_ms=0 vs >0",
          "note": null
        },
        {
